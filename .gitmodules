[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "bitriad"]
	path = bitriad
	url = https://github.com/corybrunson/bitriad
[submodule "ggalluvial"]
	path = ggalluvial
	url = https://github.com/corybrunson/ggalluvial
[submodule "gggda"]
	path = gggda
	url = https://github.com/corybrunson/gggda
[submodule "ordered"]
	path = ordered
	url = https://github.com/corybrunson/ordered
[submodule "ordr"]
	path = ordr
	url = https://github.com/corybrunson/ordr
[submodule "rgph"]
	path = rgph
	url = https://github.com/cran/rgph
